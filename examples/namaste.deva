# नमस्ते उदाहरणम् — greeting example
# चर = variable, कार्य = function, फलम् = return, दर्शय = print

कार्य अभिवादनम् (नाम) {
    फलम् "नमस्ते, " + नाम + "!"।
}

चर लोकः = "जगत्"।
दर्शय(अभिवादनम्(लोकः))।

# गणना — arithmetic and a loop
चर योगः = ०।
प्रत्येकम् (अङ्कः : [१, २, ३, ४, ५]) {
    योगः = योगः + अङ्कः।
}
दर्शय("योगः (sum):", योगः)।

# यदि / अन्यथा — conditional
यदि (योगः > १०) {
    दर्शय("दश अधिकम् (greater than ten)")।
} अन्यथा {
    दर्शय("दश न्यूनम् (ten or less)")।
}
