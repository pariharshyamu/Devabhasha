# जालपृष्ठम् — a tiny web counter
# अङ्गम् = create element, योजय = mount, श्रोता = listen

चर गणना = ०।

चर शीर्षकम् = अङ्गम्("h1", "गणकः (Counter)")।
चर प्रदर्शनम् = अङ्गम्("p", "मानम्: ०")।
चर पटः = अङ्गम्("button", "वर्धय (increment)")।

श्रोता(पटः, "click", कार्य () {
    गणना = गणना + १।
    प्रदर्शनम्.textContent = "मानम्: " + गणना।
})।

योजय(शीर्षकम्)।
योजय(प्रदर्शनम्)।
योजय(पटः)।
